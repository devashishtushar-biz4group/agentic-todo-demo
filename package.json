{
  "name": "agentic-todo-demo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": ["apps/*"],
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "eslint . --max-warnings=0",
    "lint:complexity": "eslint --config eslint.complexity.config.js . --max-warnings=0",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "eslint": "^9.14.0",
    "globals": "^15.11.0",
    "typescript-eslint": "^8.13.0"
  }
}
